rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'ADMIN';
    }

    function isCoach() {
      return isAuthenticated() && request.auth.token.role == 'COACH';
    }

    function isFamily() {
      return isAuthenticated() && request.auth.token.role == 'FAMILY';
    }

    function isCoachOrAdmin() {
      return isAdmin() || isCoach();
    }

    function hasClubAccess(clubId) {
      return isAdmin() || (isCoach() && clubId in request.auth.token.clubIds);
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Audit Logs - Admin read only, server write only
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Server only via admin SDK
    }

    // Users collection
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Children subcollection
      match /children/{childId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isOwner(uid) || isAdmin();
      }

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if false; // Server only
        allow update: if isOwner(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    // Clubs collection
    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if hasClubAccess(clubId);
      allow delete: if isAdmin();

      // Children Public subcollection (for leaderboard)
      match /childrenPublic/{childId} {
        allow read: if isAuthenticated();
        allow write: if false; // Server only via triggers
      }

      // Groups subcollection
      match /groups/{groupId} {
        allow read: if isAuthenticated();
        allow create: if hasClubAccess(clubId);
        allow update: if hasClubAccess(clubId);
        allow delete: if hasClubAccess(clubId);

        // Group members
        match /members/{memberId} {
          allow read: if isAuthenticated();
          allow write: if hasClubAccess(clubId);
        }

        // Invites
        match /invites/{inviteId} {
          allow read: if isAuthenticated();
          allow create: if hasClubAccess(clubId);
          allow update: if isAuthenticated(); // For claiming
          allow delete: if hasClubAccess(clubId);
        }
      }

      // Sessions subcollection
      match /sessions/{sessionId} {
        allow read: if isAuthenticated();
        allow create: if hasClubAccess(clubId);
        allow update: if hasClubAccess(clubId);
        allow delete: if hasClubAccess(clubId);

        // Attendance subcollection
        match /attendance/{attendanceId} {
          allow read: if isAuthenticated();
          allow write: if hasClubAccess(clubId);
        }
      }

      // Recurrences subcollection
      match /recurrences/{recurrenceId} {
        allow read: if isAuthenticated();
        allow create: if hasClubAccess(clubId);
        allow update: if hasClubAccess(clubId);
        allow delete: if hasClubAccess(clubId);
      }

      // Medal templates subcollection
      match /medalTemplates/{templateId} {
        allow read: if isAuthenticated();
        allow create: if hasClubAccess(clubId);
        allow update: if hasClubAccess(clubId);
        allow delete: if hasClubAccess(clubId);
      }

      // Medals subcollection
      match /medals/{medalId} {
        allow read: if isAuthenticated();
        allow write: if false; // Server only via callable functions
      }

      // Goals subcollection
      match /goals/{goalId} {
        allow read: if isAuthenticated();
        allow create: if hasClubAccess(clubId);
        allow update: if hasClubAccess(clubId);
        allow delete: if hasClubAccess(clubId);

        // Goal progress
        match /progress/{progressId} {
          allow read: if isAuthenticated();
          allow write: if false; // Server only
        }
      }

      // Achievements subcollection
      match /achievements/{achievementId} {
        allow read: if isAuthenticated();
        allow create: if hasClubAccess(clubId);
        allow update: if hasClubAccess(clubId);
        allow delete: if hasClubAccess(clubId);
      }
    }
  }
}
